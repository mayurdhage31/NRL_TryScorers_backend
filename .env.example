# Gemini API key — used for the RAG pipeline (File Search Tool) and chat generation
# GEMINI_API_KEY=your_key_here

PORT=8000
# Comma-separated origins allowed by CORS. Include your Vercel frontend when deployed.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://nrl-tryscorers-frontend.vercel.app
